#!/bin/sh
echo "Cleaning up after PlutoTV removal..."
rm -rf -- /usr/lib/enigma2/python/Plugins/Extensions/PlutoTV >/dev/null 2>&1
rm -rf -- /etc/enigma2/PlutoTV >/dev/null 2>&1
# remove matching names safely (handles spaces and leading `-` in names)
find /etc/enigma2/ -maxdepth 1 \( -name 'PlutoTV*' -o -name 'plutotv*' \) -exec rm -rf -- {} + 2>/dev/null
exit 0
